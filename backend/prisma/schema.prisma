generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senha      String
  cargo      Cargo    @default(COLABORADOR) // Usando o Enum Cargo
  
  workAreaId String
  workArea   WorkArea @relation(fields: [workAreaId], references: [id])

  // Relação com as tarefas que este usuário é responsável
  tasks      Task[]   @relation("UserTasks") 

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("users")
}

model Task {
  id          String     @id @default(uuid())
  titulo      String
  descricao   String?
  status      Status     @default(PENDENTE)   // Usando o Enum Status
  prioridade  Prioridade @default(MEDIA)      // Usando o Enum Prioridade

  userId      String     @map("user_id") 
  user        User       @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("tasks")
}

model WorkArea {
  id    String @id @default(uuid())
  nome  String @unique
  users User[]

  @@map("work_areas")
}

// --- ENUMS ---
enum Cargo {
  GESTOR
  COLABORADOR
  ADMIN
}

enum Status {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

enum Prioridade {
  BAIXA
  MEDIA
  ALTA
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String   
  role       String  
  workAreaId String
  workArea   WorkArea @relation(fields: [workAreaId], references: [id])
  isActive   Boolean  @default(true)
  
  managerId  String?
  manager    User?    @relation("TeamManager", fields: [managerId], references: [id])
  subordinates User[] @relation("TeamManager")

  tasks      Task[]   @relation("UserTasks")
  createdAt  DateTime @default(now())

  @@map("users")
}

model Task {
  id          String   @id @default(uuid())
  title       String  
  description String   @db.Text
  status      String
  priority    String   
  isTemplate  Boolean  @default(false)
  workAreaId  String

  userId      String?  @map("user_id")
  user        User?    @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)

  workArea    WorkArea @relation(fields: [workAreaId], references: [id])
  createdAt   DateTime @default(now())

  @@map("tasks")
}

model WorkArea {
  id        String     @id @default(uuid())
  name      String     @unique
  users     User[]
  tasks     Task[]
  materials Material[]

  @@map("work_areas")
}

model Material {
  id         String   @id @default(uuid())
  title      String  
  manager    String   
  description String  @db.Text
  fileUrl    String    @db.Text
  route      String?  
  workAreaId String
  workArea   WorkArea @relation(fields: [workAreaId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("materials")
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senha      String
  cargo      String
  workAreaId String
  workArea   WorkArea @relation(fields: [workAreaId], references: [id])
  isActive Boolean @default(true)
  
  // --- HIERARQUIA (Self-relation) ---
  managerId    String?
  manager      User?   @relation("TeamManager", fields: [managerId], references: [id])
  subordinates User[]  @relation("TeamManager")

  // --- RELAÇÃO COM TAREFAS (Ajustada para casar com Task) ---
  tasks Task[] @relation("UserTasks") // Adicionamos o nome "UserTasks" aqui!

  createdAt DateTime @default(now())
}

model Task {
  id         String  @id @default(uuid())
  titulo     String
  descricao  String
  status     String // Ou Enum se você já tiver criado
  prioridade String
  isTemplate Boolean @default(false)
  workAreaId String

  // Relação com Usuário (Dono da Task)
  userId String? @map("user_id")
  user   User?   @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  workArea  WorkArea @relation(fields: [workAreaId], references: [id])
}

model WorkArea {
  id        String     @id @default(uuid())
  nome      String     @unique
  users     User[]
  tasks     Task[] // <--- Adicione esta linha
  materials Material[]

  @@map("work_areas")
}

model Material {
  id         String   @id @default(uuid())
  titulo     String
  gestor     String
  descricao  String   @db.Text
  arquivoUrl String   @db.Text
  rota       String? // <-- ADICIONE ESTA LINHA (o ? torna opcional)
  workAreaId String
  workArea   WorkArea @relation(fields: [workAreaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("materials")
}

// --- ENUMS ---
enum Cargo {
  GESTOR
  COLABORADOR
  ADMIN
}

enum Status {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

enum Prioridade {
  BAIXA
  MEDIA
  ALTA
}

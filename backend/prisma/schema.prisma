generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  phone      String? 
  email      String   @unique
  password   String   
  role       String  
  workAreaId String
  workArea   WorkArea @relation(fields: [workAreaId], references: [id])
  startDate    DateTime?
  isActive   Boolean  @default(true)
  
  managerId  String?
  manager    User?    @relation("TeamManager", fields: [managerId], references: [id])
  subordinates User[] @relation("TeamManager")

  tasks      Task[]   @relation("UserTasks")
  employeeSignatures SignatureProcess[] @relation("EmployeeSignatures")
  createdAt  DateTime @default(now())
 
  @@map("users")
}

model Task {
  id          String   @id @default(uuid())
  title       String  
  description String   @db.Text
  status      String
  priority    String   
  isTemplate  Boolean  @default(false)
  workAreaId  String

  userId      String?  @map("user_id")
  user        User?    @relation("UserTasks", fields: [userId], references: [id], onDelete: Cascade)
  workArea    WorkArea @relation(fields: [workAreaId], references: [id])
  createdAt   DateTime @default(now())
  

@@unique([title, userId])         // ← SUBSTITUIR: mesma tarefa não pode duplicar pro mesmo usuário
@@map("tasks")
}

model WorkArea {
  id        String     @id @default(uuid())
  name      String     @unique
  users     User[]
  tasks     Task[]
  materials Material[]
  signatureProcesses SignatureProcess[]
  @@map("work_areas")
}

model Material {
  id         String   @id @default(uuid())
  title      String  
  manager    String   
  description String  @db.Text
  fileUrl    String    @db.Text
  route      String?  
  workAreaId String
  workArea   WorkArea @relation(fields: [workAreaId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("materials")
}

model SignatureProcess {
  id                String    @id @default(uuid())
  
  // Relacionamento com quem finalizou (o colaborador)
  employeeId        String
  employee          User      @relation("EmployeeSignatures", fields: [employeeId], references: [id])
  
  // Relacionamento com a área onde o processo ocorreu
  workAreaId        String
  workArea          WorkArea  @relation(fields: [workAreaId], references: [id])
  
  // Dados da assinatura
  employeeSignature String
  managerSignature  String?   // Fica nulo até o gestor assinar
  
  // Controle de status e datas
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED
  pdfUrl            String?   @db.Text
  
  completedAt       DateTime  @default(now())
  approvedAt        DateTime?
  
  @@map("signature_processes")
}

model ScheduledMessage {
  id        String   @id @default(uuid())
  phone     String
  message   String   @db.Text
  sendAt    DateTime
  status    String   @default("pending") // pending, sent, error
  createdAt DateTime @default(now())

  @@map("scheduled_messages")
}